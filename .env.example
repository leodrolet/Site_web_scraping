# ============================================================
#  Variables d'environnement — copiez ce fichier en « .env »
# ============================================================

# Clé secrète : signe les sessions utilisateur.
# Génère une vraie valeur aléatoire avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
# puis colle le résultat ci-dessous (sans espaces ni guillemets).
SECRET_KEY=change_moi_avec_une_vraie_valeur_aleatoire

# Base de données (optionnel en local).
# - Si DATABASE_URL est DÉFINIE  -> PostgreSQL (ex. Neon.tech).
# - Si elle est ABSENTE          -> repli automatique sur SQLite (fichier local).
# Format Neon (garde le « -pooler » et sslmode=require) :
#   DATABASE_URL=postgresql://utilisateur:motdepasse@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL=

# Cookies « secure » (transmis seulement en HTTPS).
# Laisse vide/false en local (HTTP). En production HTTPS -> COOKIE_SECURE=true.
# NB : sur Vercel, c'est déjà activé automatiquement.
# COOKIE_SECURE=false

# ------------------------------------------------------------
# Clés API du SERVICE (côté serveur uniquement).
# Lues par le serveur via os.getenv() — jamais exposées aux utilisateurs,
# jamais stockées en base, jamais dans le HTML/JS. Renseigne au moins Hunter.io.
# Sur Vercel : ajoute ces variables dans Settings > Environment Variables.
# ------------------------------------------------------------
HUNTER_API_KEY=
APOLLO_API_KEY=
SERPAPI_KEY=
